{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "Docente da pós-graduação",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nome completo" },
        "email": { "type": "string", "format": "email", "description": "E-mail de contato (opcional)" },
        "cpf": { "type": "string", "description": "CPF do docente (opcional)" },
        "phone": { "type": "string", "description": "Telefone de contato (opcional)" },
        "photoUrl": { "type": "string", "description": "URL da foto do docente (opcional)" },
        "linkedin": { "type": "string", "description": "Link do perfil no LinkedIn (opcional)" },
        "lattes": { "type": "string", "description": "Link do currículo Lattes (opcional)" },
        "instagram": { "type": "string", "description": "Link do perfil no Instagram (opcional)" },
        "specialties": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "courseId": { "type": "string" },
              "disciplineName": { "type": "string" }
            }
          },
          "description": "Disciplinas que o docente pode ministrar" 
        }
      },
      "required": ["name"]
    },
    "Course": {
      "title": "Course",
      "description": "Curso de pós-graduação",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nome do curso" },
        "marketingSummary": { "type": "string", "description": "Resumo de marketing/propaganda do curso (opcional)" },
        "fullDescription": { "type": "string", "description": "Descrição completa/texto publicitário (opcional)" },
        "imageUrl": { "type": "string", "description": "URL da imagem de capa do curso (opcional)" },
        "workload": { "type": "string", "description": "Carga horária (ex: 360h)" },
        "format": { "type": "string", "description": "Formato (ex: Presencial, Remoto)" },
        "classDays": { "type": "string", "description": "Dias de aula (ex: Sábados)" },
        "classTime": { "type": "string", "description": "Horário das aulas (ex: 08:00 - 17:00)" },
        "duration": { "type": "string", "description": "Duração do curso (ex: 10 meses)" },
        "enrollmentPeriod": { "type": "string", "description": "Período de inscrições (ex: 15/12/25 até 28/03/26)" },
        "startDateInfo": { "type": "string", "description": "Informação de início das aulas (ex: 30/01/26)" },
        "enrollmentStatus": { "type": "string", "description": "Status de matrículas (ex: Abertas, Em andamento)" },
        "websiteUrl": { "type": "string", "description": "Link oficial do curso no site da ESUDA (opcional)" },
        "specificDisciplines": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista das 9 disciplinas específicas"
        }
      },
      "required": ["name", "specificDisciplines"]
    },
    "Holiday": {
      "title": "Holiday",
      "description": "Feriado que bloqueia aulas",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "Data do feriado (YYYY-MM-DD)" },
        "description": { "type": "string", "description": "Nome do feriado" }
      },
      "required": ["date", "description"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Cronograma de uma turma (grupo de cursos)",
      "type": "object",
      "properties": {
        "courseIds": { "type": "array", "items": { "type": "string" }, "description": "IDs dos cursos agrupados" },
        "className": { "type": "string", "description": "Nome da turma (ex: Turma A - 2024)" },
        "startDate": { "type": "string", "format": "date", "description": "Data de início das aulas" },
        "status": { "type": "string", "enum": ["active", "archived"], "description": "Status do cronograma" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["courseIds", "className", "startDate", "status"]
    },
    "ClassSession": {
      "title": "ClassSession",
      "description": "Sessão individual de aula (um sábado)",
      "type": "object",
      "properties": {
        "scheduleId": { "type": "string", "description": "ID do cronograma pai" },
        "date": { "type": "string", "format": "date", "description": "Data da aula" },
        "disciplineName": { "type": "string", "description": "Nome da disciplina" },
        "teacherId": { "type": "string", "description": "ID do docente" },
        "courseId": { "type": "string", "description": "ID do curso (se for específica) ou 'all' (se for comum)" },
        "courseName": { "type": "string", "description": "Nome do curso para exibição rápida" },
        "order": { "type": "integer", "description": "Ordem da disciplina (1-18)" },
        "classNumber": { "type": "integer", "description": "Número da aula dentro da disciplina (1 ou 2)" },
        "isCommon": { "type": "boolean", "description": "Se é uma disciplina comum" }
      },
      "required": ["scheduleId", "date", "disciplineName", "order", "isCommon"]
    }
  },
  "firestore": {
    "teachers": { "schema": "Teacher", "description": "Coleção de professores" },
    "courses": { "schema": "Course", "description": "Coleção de cursos" },
    "holidays": { "schema": "Holiday", "description": "Coleção de feriados" },
    "schedules": { "schema": "Schedule", "description": "Coleção de cronogramas mestres" },
    "classes": { "schema": "ClassSession", "description": "Coleção de sessões de aula individuais" }
  }
}
